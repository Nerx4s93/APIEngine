<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
		
		<ImplicitUsings>disable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<PackageId>APIEngine</PackageId>
		<Version>1.0.2</Version>
		<Authors>Nerx4s93</Authors>
		<Description>A lightweight extensible HTTP client engine for building API SDKs with middleware-style request pipelines, low-level HTTP access, and customizable request/response processing.</Description>
		<PackageTags>http;api;client;sdk;engine;rest;restclient;middleware;httprequest;httpclient;dotnet;serialization;streaming;json</PackageTags>

		<RepositoryUrl>https://github.com/Nerx4s93/APIEngine</RepositoryUrl>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>

		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<IncludeSymbols>true</IncludeSymbols>
	</PropertyGroup>

</Project>
